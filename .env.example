# Copy to `.env` and adjust. Vite loads these from the project root (same folder as `vite.config.ts`).

# Public site URL (https, no trailing slash). Injected into canonical + og:url at build time.
# If unset, those tags are omitted (see `vitePluginHtmlGuards` in `vite.config.ts`).
# VITE_SITE_URL=https://your-domain.com

# Umami — both must be set or no script is emitted (no `/umami` 404 in dev/prod).
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=
